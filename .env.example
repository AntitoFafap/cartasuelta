# CONFIGURACIÓN DE SEGURIDAD
# Copia este archivo a .env.local y actualiza los valores

# Ambiente (production o development)
NODE_ENV=development

# Configuración de sesión
SESSION_EXPIRY_HOURS=24

# Rate limiting
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# Validación de entrada
MAX_NAME_LENGTH=100
MAX_SET_LENGTH=100
MIN_PASSWORD_LENGTH=6

# HTTPS (en producción, debe ser true)
FORCE_HTTPS=false

# Content Security Policy
CSP_ENABLED=true

# CORS (si necesitas APIs públicas)
CORS_ENABLED=false
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_SECURITY_EVENTS=true

# =============================================
# SMTP Email (Nodemailer)
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASS=contraseña

# Nombre de la aplicación para los emails
APP_NAME=Pokemon Cards Store
# =============================================
# Base de datos MySQL
# =============================================
DB_HOST=localhost
DB_USER=user
DB_PASS=password
DB_NAME=dbname

# =============================================
# Pagos - WebPay (Transbank)
# =============================================
# Ambiente: 'integration' (pruebas) o 'production'
WEBPAY_ENVIRONMENT=integration

# Credenciales de producción (solo si WEBPAY_ENVIRONMENT=production)
# Solicitar en: https://www.transbank.cl/
WEBPAY_COMMERCE_CODE=597055555532
WEBPAY_API_KEY=tu-api-key-de-produccion

# =============================================
# Pagos - Mercado Pago
# =============================================
# Obtener en: https://www.mercadopago.cl/developers/panel/credentials
# En ambiente de pruebas, usar el Access Token de Test
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxx-xxxx-xxxx-xxxx-xxxxxxxx

# Public Key (opcional, para checkout frontend)
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxx-xxxx-xxxx-xxxx-xxxxxxxx

# =============================================
# URL Base de la aplicación
# =============================================
# Necesaria para las URLs de retorno de los pagos
NEXT_PUBLIC_BASE_URL=http://localhost:3000
